# =====================================================
# 🔑 エンカンAI 接続キー設定ファイル（テンプレート）
# =====================================================
# 
# 📌 このファイルの使い方
# 1. このファイル名を「secrets.toml.example」から
#    「secrets.toml」に変更してください
#    （末尾の「.example」を消すだけでOK）
# 2. 下の3つの「ここに〜を入れる」の部分に、
#    管理者から渡された値をコピペしてください
# 3. 保存して閉じる
#
# ⚠️ 絶対にやってはいけないこと
# ・このファイルを誰かにメールやチャットで送る
# ・このファイルをGitHubにアップロードする
# （※「.gitignore」で守られていますが念のため）
# =====================================================

SUPABASE_URL = "ここにSupabaseのURLを入れる"
SUPABASE_KEY = "ここにSupabaseのキーを入れる"
GEMINI_API_KEY = "ここにGeminiのAPIキーを入れる"

# --- 任意（無くても動きます）---
# 完了/失敗を Slack に通知したいときだけ、Slack の Incoming Webhook URL を入れる。
# 未設定なら通知はしません（アプリは通常どおり動きます）。
# SLACK_WEBHOOK_URL = "https://hooks.slack.com/services/XXX/YYY/ZZZ"
