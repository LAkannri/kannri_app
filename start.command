#!/bin/bash
cd "$(dirname "$0")"

clear
echo ""
echo "================================================"
echo "   🤖 エンカンAI を起動します"
echo "================================================"
echo ""

# ----------------------------------------
# 🆕 初回起動なら、マニュアルをブラウザで自動オープン
# ----------------------------------------
if [ ! -f ".setup_done" ]; then
    echo "【初めてのご利用】セットアップガイドを開きます..."
    if [ -f "はじめにお読みください.html" ]; then
        open "はじめにお読みください.html"
    fi
    sleep 2
    echo ""
fi

# ----------------------------------------
# Pythonが入っているかチェック
# ----------------------------------------
if ! command -v python3 &> /dev/null; then
    echo "❌ Pythonが見つかりません！"
    echo ""
    echo "開いているマニュアルの【STEP 1】を見て、"
    echo "Pythonをインストールしてからもう一度起動してください。"
    echo ""
    read -p "Enterキーを押して閉じてください..."
    exit 1
fi

# ----------------------------------------
# 初回セットアップ（最初の1回だけ）
# ----------------------------------------
if [ ! -f ".setup_done" ]; then
    echo "【初回セットアップ中】"
    echo "必要な部品をダウンロードしています..."
    echo "これには5〜10分ほどかかります。"
    echo "マニュアルを読みながらお待ちください ☕"
    echo ""
    echo "----------------------------------------"
    
    python3 -m pip install --upgrade pip
    if [ $? -ne 0 ]; then
        echo "❌ pipの更新に失敗しました。"
        echo "インターネット接続を確認してもう一度お試しください。"
        read -p "Enterキーを押して閉じてください..."
        exit 1
    fi
    
    pip3 install -r requirements.txt
    if [ $? -ne 0 ]; then
        echo "❌ 部品のインストールに失敗しました。"
        echo "マニュアルの【困ったとき】を見てください。"
        read -p "Enterキーを押して閉じてください..."
        exit 1
    fi
    
    python3 -m playwright install chromium
    if [ $? -ne 0 ]; then
        echo "❌ ブラウザのインストールに失敗しました。"
        read -p "Enterキーを押して閉じてください..."
        exit 1
    fi
    
    touch .setup_done
    echo ""
    echo "----------------------------------------"
    echo "✅ セットアップ完了！次回からはすぐ起動します。"
    echo "----------------------------------------"
    echo ""
fi

# ----------------------------------------
# secrets.toml があるかチェック
# ----------------------------------------
if [ ! -f ".streamlit/secrets.toml" ]; then
    echo "❌ 接続キーの設定ファイルがありません！"
    echo ""
    echo "マニュアルの【STEP 3】を見て、"
    echo "secrets.toml を設置してからもう一度起動してください。"
    echo ""
    if [ -f "はじめにお読みください.html" ]; then
        open "はじめにお読みください.html"
    fi
    read -p "Enterキーを押して閉じてください..."
    exit 1
fi

# ----------------------------------------
# Streamlit起動
# ----------------------------------------
echo "エンカンAIを起動中..."
echo ""
echo "ブラウザが自動で開きます。少々お待ちください。"
echo ""
echo "⚠️ この黒い画面は閉じないでください！"
echo "   閉じるとエンカンAIも止まります。"
echo "   終わるときは Control+C を押してください。"
echo ""

streamlit run app.py
